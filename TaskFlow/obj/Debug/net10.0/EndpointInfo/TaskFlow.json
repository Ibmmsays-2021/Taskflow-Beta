{
  "openapi": "3.1.1",
  "info": {
    "title": "TaskFlow | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7100"
    },
    {
      "url": "http://localhost:5032"
    }
